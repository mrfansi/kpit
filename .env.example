# Required: Random secret for NextAuth.js session encryption (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your-random-secret-here

# Initial admin user credentials for seed script (npm run seed:admin)
# IMPORTANT: Set strong values before running seed:admin
# Generate password: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Optional: Webhook URL for red KPI notifications (supports Slack/Discord/custom)
# Leave empty to disable notifications
NOTIFY_WEBHOOK_URL=

# Optional: Google AI API key for AI narrative in executive report
# Get from: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
